        <mxCell id="200" value="&lt;b&gt;Modifying&lt;/b&gt;  (Sequential, Merge Results)" style="swimlane;html=1;startSize=22;fillColor=#E3F2FD;strokeColor=#6c8ebf;rounded=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="400" y="50" width="380" height="180" as="geometry"/></mxCell>
