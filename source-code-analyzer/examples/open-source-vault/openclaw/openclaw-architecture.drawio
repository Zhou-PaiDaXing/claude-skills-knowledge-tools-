        <mxCell id="301" value="First handler returning {handled:true} wins" style="text;html=1;fontSize=9;fontColor=#666;align=left;" vertex="1" parent="300"><mxGeometry x="10" y="25" width="300" height="16" as="geometry"/></mxCell>
